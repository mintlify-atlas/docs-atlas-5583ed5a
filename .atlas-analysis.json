  "keyFeatures": [
    "Persistent State with automatic sync to connected clients",
    "Type-safe RPC via @callable() decorator",
    "Built-in scheduling (one-time, recurring, cron)",
    "WebSocket hibernation with lifecycle hooks",
    "AI chat with message persistence and resumable streaming",
    "MCP server and client support",
    "Durable workflows with human-in-the-loop",
    "Email routing via Cloudflare Email Routing",
    "React hooks for frontend integration",
    "Direct SQLite queries via Durable Objects"
  ],
  "publicApiSurface": [
    "Agent - Base class for creating agents",
    "routeAgentRequest - Router for agent requests",
    "@callable() - Decorator for RPC methods",
    "setState/getState - State management",
    "schedule/cancelSchedule - Scheduling API",
    "McpAgent - Base class for MCP servers",
    "MCPClientManager - MCP client connections",
    "AgentWorkflow - Workflow orchestration",
    "EmailAgent - Email handling",
    "useAgent - React hook for agent state",
    "useAgentChat - React hook for AI chat",
    "AgentClient - Vanilla JS client",
    "ChatAgent - Higher-level AI chat agent",
    "codeMode - Experimental code generation"
  ]
}
